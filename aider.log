        const data = await res.json();                                          
                                                                                
        throw new Error(data.error || "Could not delete this listing.");        
                                                                                
      }                                                                         
                                                                                
      setListings((prev) => prev.filter((item) => item.id !== id));             
                                                                                
    } catch (err) {                                                             
                                                                                
      setActionError(                                                           
                                                                                
        err instanceof Error ? err.message : "Could not delete this listing."   
                                                                                
